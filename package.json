{
  "name": "@surajnarwade/plugin-tech-insights-mcp-actions-backend",
  "version": "0.1.0",
  "license": "MIT",
  "description": "MCP actions for the Backstage tech-insights plugin. Exposes tech-insights checks, facts, and entity insights as MCP tools.",
  "repository": {
    "type": "git",
    "url": "https://github.com/surajnarwade/tech-insights-mcp-actions-backend"
  },
  "bugs": {
    "url": "https://github.com/surajnarwade/tech-insights-mcp-actions-backend/issues"
  },
  "homepage": "https://github.com/surajnarwade/tech-insights-mcp-actions-backend#readme",
  "keywords": [
    "backstage",
    "backstage-plugin",
    "mcp",
    "tech-insights",
    "model-context-protocol"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts"
  },
  "backstage": {
    "role": "backend-plugin",
    "pluginId": "tech-insights-mcp-actions"
  },
  "scripts": {
    "start": "backstage-cli package start",
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test -- --watchman=false",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack"
  },
  "dependencies": {
    "@backstage/backend-plugin-api": "^1.8.0",
    "@backstage/catalog-model": "^1.7.6",
    "@backstage/errors": "^1.2.6",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.0",
    "@backstage/cli-defaults": "^0.1.0",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "files": [
    "dist"
  ]
}
